{
  "name": "stash",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "0.5.0",
  "scripts": {
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "tscheck": "turbo run tscheck",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "validate": "tsx scripts/validate.ts",
    "screenshots": "tsx scripts/generate-screenshots.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.12.4",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "playwright": "^1.60.0",
    "tasuku": "^2.3.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "wrangler": "^3.90.0",
    "zx": "^8.8.5"
  },
  "packageManager": "pnpm@11.5.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@getgauge/cli",
      "esbuild",
      "protobufjs",
      "sharp",
      "spawn-sync"
    ]
  }
