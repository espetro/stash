{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["chrome", "webextension-polyfill", "react", "react-dom"],
    "baseUrl": ".",
    "paths": {
      "#*": ["./*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".wxt", "dist"]
}
