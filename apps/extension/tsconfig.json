{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@/lib/*": ["./lib/*"],
      "@/components/*": ["./components/*"],
      "@/modules/*": ["./modules/*"],
      "@/entrypoints/*": ["./entrypoints/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
