{
  "name": "@tab-mail/extension",
  "version": "0.2.0",
  "description": "Browser extension for sharing tabs via URL-encoded links",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wxt dev",
    "dev:firefox": "wxt dev -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt clean",
    "compile": "tsc --noEmit",
    "release": "release-it"
  },
  "dependencies": {
    "@tab-mail/codec": "workspace:*",
    "@tab-mail/theme": "workspace:*",
    "brotli-wasm": "^3.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^8.0.2",
    "@types/chrome": "^0.1.37",
    "@types/pako": "^2.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@wxt-dev/module-react": "^1.2.1",
    "release-it": "^19.2.4",
    "typescript": "^5.9.3",
    "wxt": "^0.20.19"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  }
}
