{
  "name": "stash-extension",
  "version": "0.2.0",
  "private": true,
  "description": "Stash browser extension",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "pnpm run build:chrome & pnpm run build:firefox",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "pnpm run zip:chrome & pnpm run zip:firefox",
    "zip:chrome": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "format": "oxfmt --write 'entrypoints/**/*.{ts,tsx}' 'lib/**/*.{ts,tsx}'",
    "lint": "oxlint 'entrypoints/**/*.{ts,tsx}' 'lib/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts'",
    "tscheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stash/codec": "workspace:*",
    "@stash/theme": "workspace:*",
    "brotli-wasm": "^3.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "webext-storage": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@wxt-dev/module-react": "^1.2.2",
    "geist": "^1.7.0",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  }
}