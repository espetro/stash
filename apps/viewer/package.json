{
  "name": "stash-viewer",
  "version": "0.5.0",
  "private": true,
  "description": "Stash viewer site",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "oxfmt --write 'src/**/*.{ts,tsx,astro}'",
    "lint": "oxlint 'src/**/*.{ts,tsx,astro}' --ignore-pattern '**/*.d.ts'",
    "tscheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@astrojs/starlight": "^0.39.2",
    "@lucide/astro": "^1.14.0",
    "@msgpack/msgpack": "^3.1.3",
    "@stash/codec": "workspace:*",
    "@stash/theme": "workspace:*",
    "astro": "^6.3.1",
    "brotli-wasm": "^3.0.1",
    "geist": "^1.7.0",
    "lean-qr": "^2.7.1",
    "lucide-react": "^1.16.0",
    "markdown-escape": "^2.0.0",
    "neverthrow": "8.2.0",
    "pako": "^2.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260526.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "postcss": "^8.5.15",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}