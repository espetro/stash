    "brotli-wasm": "^3.0.1",
    "geist": "^1.7.0",
    "markdown-escape": "^2.0.0",
    "pako": "^2.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0"
