---
interface Props {
  title: string;
}
const { title } = Astro.props;
const posthogKey = import.meta.env.VITE_POSTHOG_KEY;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="google-site-verification" content="dJbisPrLjFw4YbDPfmdhJtV27zFTjh8ZpOqXAFoTzAE" />
  <link rel="icon" type="image/png" href="/icon-128.png" sizes="128x128" />
  <link rel="icon" type="image/png" href="/icon-48.png" sizes="48x48" />
  <link rel="apple-touch-icon" href="/icon-128.png" />
  <title>{title}</title>
  {/* AI agent consumption — alternate representations of this stash page */}
  {Astro.url.pathname.startsWith('/s') && (
    <>
      <link rel="alternate" type="application/json" href={Astro.url + '?format=json'} title="Stash as JSON" />
      <link rel="alternate" type="text/markdown" href={Astro.url + '?format=md'} title="Stash as Markdown" />
    </>
  )}
  {posthogKey && (
    <script>
      window.posthog = window.posthog || {};
      (function() {
        const key = '{posthogKey}';
        if (!key) return;

        const script = document.createElement('script');
        script.async = true;
        script.src = 'https://us-assets.i.posthog.com/array.js';
        script.onload = function() {
          if (window.posthog && typeof window.posthog.init === 'function') {
            window.posthog.init(key, {
              api_host: 'https://us.i.posthog.com',
              persistence: 'memory',
              autocapture: true,
              capture_pageview: true,
            });
          }
        };
        document.head.appendChild(script);
      })();
    </script>
  )}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script>
    import { initTheme } from '@stash/theme';
    initTheme(localStorage);
  </script>
  <style is:global>
    @import '@/styles/global.css';
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
