---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import CardHeader from '../components/CardHeader.astro';
import ActionBar from '../components/ActionBar.astro';
import TabList from '../components/TabList.astro';
import TabItem from '../components/TabItem.astro';
---

<Layout title="Stash Viewer">
  <div id="app">
    <!-- Loading state -->
    <div id="loading">Loading...</div>
    
    <!-- Error/Expired state -->
    <div id="error" style="display: none;"></div>
    
    <!-- Content state -->
    <div id="content" style="display: none;">
      <div class="card">
        <div class="header">
          <ThemeToggle />
          <CardHeader />
        </div>
        
        <ActionBar />
        <TabList />
      </div>
    </div>
  </div>

  <style>
    @import "tailwindcss";

    #app {
      min-height: 100vh;
      background: var(--background);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    :global(#output) {
      font-family: monospace;
      font-size: 13px;
      line-height: 1.5;
      color: var(--foreground);
      background: var(--background);
      margin: 0;
      padding: 8px;
      white-space: pre-wrap;
      word-break: break-word;
      border: none;
      display: block;
      width: 100%;
      box-sizing: border-box;
    }

    #loading,
    #error {
      color: var(--foreground);
      font-size: 1.25rem;
      text-align: center;
    }

    .card {
      background: var(--background);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      max-width: 600px;
      width: 100%;
      padding: 32px;
    }

    .header {
      position: relative;
      text-align: center;
      margin-bottom: 24px;
    }
  </style>

  <script>
    import { decodeShareUrl, PayloadDecodeError } from '@stash/codec';
    import { getBrotliFunctions } from '../lib/brotli';
    import { createTabItemElement } from '../lib/tab-item';
    import markdownEscape from 'markdown-escape';

    const loadingEl = document.getElementById('loading')!;
    const errorEl = document.getElementById('error')!;
    const contentEl = document.getElementById('content')!;
    const itemCountEl = document.getElementById('item-count')!;
    const expiryTimerEl = document.getElementById('expiry-timer')!;
    const tabListEl = document.getElementById('tab-list')!;
    const openAllBtn = document.getElementById('open-all')!;
    const copyUrlsBtn = document.getElementById('copy-urls')!;

    let decodedData: any = null;

    function getFormatParam(): string | null {
      const raw = new URLSearchParams(window.location.search).get('format');
      return raw ? raw.toLowerCase() : null;
    }

    async function init() {
      try {
        const format = getFormatParam();
        const fragment = window.location.hash;

        if (!fragment) {
          showError('No share data found in URL');
          return;
        }

        const brotli = await getBrotliFunctions();
        decodedData = await decodeShareUrl(fragment, brotli);

        if (decodedData.isExpired) {
          showError('This share link has expired');
          return;
        }

        if (format === 'json') {
          renderJson(decodedData);
        } else if (format === 'md') {
          renderMarkdown(decodedData);
        } else {
          showContent(decodedData);
        }
      } catch (error) {
        console.error('Failed to decode share URL:', error);
        if (error instanceof PayloadDecodeError) {
          showError(error.message);
        } else {
          showError('Failed to load shared tabs');
        }
      }
    }

    function showError(message: string) {
      loadingEl.style.display = 'none';
      errorEl.textContent = message;
      errorEl.style.display = 'block';
    }

    function renderJson(data: any) {
      loadingEl.style.display = 'none';
      const appEl = document.getElementById('app')!;
      appEl.style.display = 'block';
      appEl.style.padding = '0';

      const output = {
        expiry: data.expiry,
        isExpired: data.isExpired,
        items: data.items.map(([url, title]: [string, string]) => ({ url, title }))
      };
      const pre = document.createElement('pre');
      pre.id = 'output';
      pre.textContent = JSON.stringify(output, null, 2);
      appEl.appendChild(pre);
    }

    function renderMarkdown(data: any) {
      loadingEl.style.display = 'none';
      const appEl = document.getElementById('app')!;
      appEl.style.display = 'block';
      appEl.style.padding = '0';

      const lines = data.items.map(([url, title]: [string, string]) => {
        return `[${markdownEscape(title)}](${url})`;
      });
      const pre = document.createElement('pre');
      pre.id = 'output';
      pre.textContent = lines.join('\n');
      appEl.appendChild(pre);
    }

    function formatRemainingTime(expiryTimestamp: number): string {
      const now = Math.floor(Date.now() / 1000);
      const remainingSeconds = expiryTimestamp - now;

      if (remainingSeconds <= 0) {
        return 'Expired';
      }

      // 10 years in seconds
      const TEN_YEARS_SECONDS = 10 * 365 * 24 * 60 * 60;
      if (remainingSeconds > TEN_YEARS_SECONDS) {
        return 'No expiration date';
      }

      const hours = Math.floor(remainingSeconds / 3600);
      const minutes = Math.floor((remainingSeconds % 3600) / 60);

      if (hours > 0) {
        return `Expires in ${hours}h ${minutes}m`;
      } else if (minutes > 0) {
        return `Expires in ${minutes}m`;
      } else {
        return 'Expires in < 1m';
      }
    }

    function showContent(data: any) {
      loadingEl.style.display = 'none';
      contentEl.style.display = 'block';

      const count = data.items.length;
      itemCountEl.textContent = `${count} Item${count !== 1 ? 's' : ''}`;
      expiryTimerEl.textContent = formatRemainingTime(data.expiry);

      tabListEl.innerHTML = '';
      data.items.forEach(([url, title]: [string, string]) => {
        tabListEl.appendChild(createTabItemElement(url, title));
      });

      openAllBtn.addEventListener('click', openAllTabs);
      copyUrlsBtn.addEventListener('click', copyUrls);
    }

    function openAllTabs() {
      if (!decodedData) return;
      decodedData.items.forEach(([url]: [string, string]) => {
        window.open(url, '_blank');
      });
    }

    async function copyUrls() {
      if (!decodedData) return;

      const lines = decodedData.items.map(([url, title]: [string, string]) => {
        return `[${markdownEscape(title)}](${url})`;
      });
      const text = lines.join('\n');

      try {
        await navigator.clipboard.writeText(text);
        copyUrlsBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyUrlsBtn.textContent = 'Copy URLs';
        }, 2000);
      } catch (error) {
        console.error('Failed to copy URLs:', error);
      }
    }

    init();
  </script>
</Layout>
