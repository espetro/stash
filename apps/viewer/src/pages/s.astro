---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TabShare Viewer">
  <div id="app">
    <!-- Loading state -->
    <div id="loading">Loading...</div>
    
    <!-- Error/Expired state -->
    <div id="error" style="display: none;"></div>
    
    <!-- Content state -->
    <div id="content" style="display: none;">
      <div class="card">
        <div class="header">
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" title="Toggle theme">🖥️</button>
          <div class="folder-icon">📁</div>
          <h1 id="item-count">0 Items</h1>
        </div>
        
        <div class="actions">
          <button id="open-all" class="btn btn-primary">Open All Tabs</button>
          <button id="copy-urls" class="btn btn-secondary">Copy URLs</button>
        </div>
        
        <div class="tab-list" id="tab-list">
          <!-- Tab items will be rendered here -->
        </div>
      </div>
    </div>
  </div>

  <style>
    #app {
      min-height: 100vh;
      background: var(--background);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    :global(#output) {
      font-family: monospace;
      font-size: 13px;
      line-height: 1.5;
      color: var(--foreground);
      background: var(--background);
      margin: 0;
      padding: 8px;
      white-space: pre-wrap;
      word-break: break-word;
      border: none;
      display: block;
      width: 100%;
      box-sizing: border-box;
    }

    #loading,
    #error {
      color: var(--foreground);
      font-size: 1.25rem;
      text-align: center;
    }

    .card {
      background: var(--background);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      max-width: 600px;
      width: 100%;
      padding: 32px;
    }

    .header {
      position: relative;
      text-align: center;
      margin-bottom: 24px;
    }

    .theme-toggle {
      position: absolute;
      top: 0;
      right: 0;
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 4px;
      font-size: 1.125rem;
      line-height: 1;
      border-radius: var(--radius-sm);
      transition: background-color 0.2s ease;
    }

    .theme-toggle:hover {
      background-color: var(--muted);
    }

    .theme-toggle:focus-visible {
      outline: 2px solid var(--ring);
      outline-offset: 2px;
    }

    .folder-icon {
      font-size: 3rem;
      margin-bottom: 12px;
    }

    .header h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin: 0;
      color: var(--foreground);
    }

    .actions {
      display: flex;
      gap: 12px;
      margin-bottom: 24px;
    }

    .btn {
      flex: 1;
      padding: 12px 20px;
      border: none;
      border-radius: var(--radius-lg);
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }

    .btn:active {
      transform: translateY(0);
    }

    .btn-primary {
      background: var(--primary);
      color: var(--primary-foreground);
    }

    .btn-primary:hover {
      background: var(--primary);
    }

    .btn-secondary {
      background: var(--secondary);
      color: var(--foreground);
    }

    .btn-secondary:hover {
      background: var(--border);
    }

    .tab-list {
      max-height: 400px;
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
    }

    :global(.tab-item) {
      display: flex;
      align-items: flex-start;
      padding: 12px 16px;
      gap: 10px;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      color: inherit;
      transition: background-color 0.2s ease;
    }

    :global(.tab-item:last-child) {
      border-bottom: none;
    }

    :global(.tab-item:hover) {
      background-color: var(--muted);
    }

    :global(.tab-favicon) {
      width: 16px;
      height: 16px;
      margin-top: 2px;
      flex-shrink: 0;
    }

    :global(.tab-favicon.error) {
      display: none;
    }

    :global(.tab-content) {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    :global(.tab-title) {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--foreground);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    :global(.tab-url) {
      font-size: 0.75rem;
      color: var(--muted-foreground);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Scrollbar styling */
    .tab-list::-webkit-scrollbar {
      width: 8px;
    }

    .tab-list::-webkit-scrollbar-track {
      background: var(--muted);
      border-radius: 4px;
    }

    .tab-list::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 4px;
    }

    .tab-list::-webkit-scrollbar-thumb:hover {
      background: var(--muted-foreground);
    }
  </style>

  <script>
    import { decodeShareUrl, getFaviconUrl } from '../lib/decoder.js';
    import { PayloadDecodeError } from '../lib/types.js';
    import { getTheme, setTheme } from '@tab-mail/theme';

    type Theme = 'light' | 'dark' | 'system';

    const THEME_ICONS: Record<Theme, string> = {
      light: '☀️',
      dark: '🌙',
      system: '🖥️',
    };

    const THEME_ORDER: Theme[] = ['light', 'dark', 'system'];

    const themeToggleBtn = document.getElementById('theme-toggle')!;
    let currentTheme: Theme = getTheme();

    function updateThemeButton() {
      themeToggleBtn.textContent = THEME_ICONS[currentTheme];
    }

    function cycleTheme() {
      const currentIndex = THEME_ORDER.indexOf(currentTheme);
      const nextIndex = (currentIndex + 1) % THEME_ORDER.length;
      currentTheme = THEME_ORDER[nextIndex];
      setTheme(currentTheme);
      updateThemeButton();
    }

    // Initialize theme button
    updateThemeButton();
    themeToggleBtn.addEventListener('click', cycleTheme);

    const loadingEl = document.getElementById('loading')!;
    const errorEl = document.getElementById('error')!;
    const contentEl = document.getElementById('content')!;
    const itemCountEl = document.getElementById('item-count')!;
    const tabListEl = document.getElementById('tab-list')!;
    const openAllBtn = document.getElementById('open-all')!;
    const copyUrlsBtn = document.getElementById('copy-urls')!;

    // Store decoded data for button actions
    let decodedData: any = null;

    function getFormatParam(): string | null {
      const raw = new URLSearchParams(window.location.search).get('format');
      return raw ? raw.toLowerCase() : null;
    }

    async function init() {
      try {
        const format = getFormatParam();
        const fragment = window.location.hash;

        if (!fragment) {
          showError('No share data found in URL');
          return;
        }

        decodedData = await decodeShareUrl(fragment);

        if (decodedData.isExpired) {
          showError('This share link has expired');
          return;
        }

        if (format === 'json') {
          renderJson(decodedData);
        } else if (format === 'md') {
          renderMarkdown(decodedData);
        } else {
          showContent(decodedData);
        }

      } catch (error) {
        console.error('Failed to decode share URL:', error);
        if (error instanceof PayloadDecodeError) {
          showError(error.message);
        } else {
          showError('Failed to load shared tabs');
        }
      }
    }

    function showError(message: string) {
      loadingEl.style.display = 'none';
      errorEl.textContent = message;
      errorEl.style.display = 'block';
    }

    function renderJson(data: any) {
      loadingEl.style.display = 'none';
      const appEl = document.getElementById('app')!;
      appEl.style.display = 'block';
      appEl.style.padding = '0';

      const output = {
        expiry: data.expiry,
        isExpired: data.isExpired,
        items: data.items.map(([url, title]: [string, string]) => ({ url, title }))
      };
      const pre = document.createElement('pre');
      pre.id = 'output';
      pre.textContent = JSON.stringify(output, null, 2);
      appEl.appendChild(pre);
    }

    function renderMarkdown(data: any) {
      loadingEl.style.display = 'none';
      const appEl = document.getElementById('app')!;
      appEl.style.display = 'block';
      appEl.style.padding = '0';

      const lines = data.items.map(([url, title]: [string, string]) => {
        const safeTitle = title.replace(/\[/g, '\\[').replace(/\]/g, '\\]');
        return `[${safeTitle}](${url})`;
      });
      const pre = document.createElement('pre');
      pre.id = 'output';
      pre.textContent = lines.join('\n');
      appEl.appendChild(pre);
    }

    function showContent(data: any) {
      loadingEl.style.display = 'none';
      contentEl.style.display = 'block';

      // Set item count
      const count = data.items.length;
      itemCountEl.textContent = `${count} Item${count !== 1 ? 's' : ''}`;

      // Render tab list
      tabListEl.innerHTML = '';
      
      data.items.forEach(([url, title]: [string, string]) => {
        const faviconUrl = getFaviconUrl(url);

        const itemEl = document.createElement('a');
        itemEl.className = 'tab-item';
        itemEl.href = url;
        itemEl.target = '_blank';
        itemEl.rel = 'noopener noreferrer';

        const faviconEl = document.createElement('img');
        faviconEl.className = 'tab-favicon';
        faviconEl.src = faviconUrl;
        faviconEl.alt = '';
        faviconEl.onerror = function() {
          this.classList.add('error');
        };

        const contentEl = document.createElement('div');
        contentEl.className = 'tab-content';

        const titleEl = document.createElement('span');
        titleEl.className = 'tab-title';
        titleEl.textContent = title;

        const urlEl = document.createElement('span');
        urlEl.className = 'tab-url';
        urlEl.textContent = url;

        contentEl.appendChild(titleEl);
        contentEl.appendChild(urlEl);

        itemEl.appendChild(faviconEl);
        itemEl.appendChild(contentEl);

        tabListEl.appendChild(itemEl);
      });

      // Wire up buttons
      openAllBtn.addEventListener('click', openAllTabs);
      copyUrlsBtn.addEventListener('click', copyUrls);
    }

    function openAllTabs() {
      if (!decodedData) return;

      decodedData.items.forEach(([url]: [string, string]) => {
        window.open(url, '_blank');
      });
    }

    async function copyUrls() {
      if (!decodedData) return;

      const urls = decodedData.items.map(([url]: [string, string]) => url).join('\n');

      try {
        await navigator.clipboard.writeText(urls);
        copyUrlsBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyUrlsBtn.textContent = 'Copy URLs';
        }, 2000);
      } catch (error) {
        console.error('Failed to copy URLs:', error);
      }
    }

    // Initialize on page load
    init();
  </script>
</Layout>
