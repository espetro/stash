---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stash - Share Tabs via URL">
  <main class="flex min-h-screen items-center justify-center">
    <div class="text-center">
      <h1 class="text-4xl font-bold text-purple-600 mb-4">Stash</h1>
      <p class="text-gray-600 mb-6">Share browser tabs via URL-encoded links</p>
      <a
        href="/s"
        class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition-colors"
      >
        Open Viewer
      </a>
      <p class="mt-8 text-sm text-gray-500">
        Install the browser extension to create share links from your tabs.
      </p>
    </div>
  </main>
</Layout>
