---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/landing/Navbar.astro';
import Footer from '../components/landing/Footer.astro';
---

<Layout title="Privacy Policy — Stash">
  <Navbar />
  <main class="page-main">
    <div class="page-container">

      <!-- Page header -->
      <header class="page-header">
        <span class="page-label">PRIVACY POLICY</span>
        <h1 class="page-title">No Data Collection</h1>
        <p class="page-subtitle">
          Stash is designed with privacy as a core principle. Here's exactly what happens — and what doesn't.
        </p>
      </header>

      <!-- Policy items -->
      <ul class="policy-list" role="list">
        <li class="policy-item">
          <svg class="check-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="8" stroke="#3981F6" stroke-width="1.5"/>
            <path d="M5.5 9L7.5 11L12.5 6.5" stroke="#3981F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <strong>No personal data is collected.</strong> We don't track you, store cookies, or gather any information about you.
          </div>
        </li>
        <li class="policy-item">
          <svg class="check-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="8" stroke="#3981F6" stroke-width="1.5"/>
            <path d="M5.5 9L7.5 11L12.5 6.5" stroke="#3981F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <strong>All sharing happens locally in your browser.</strong> Stash selection and link generation occur entirely on your device.
          </div>
        </li>
        <li class="policy-item">
          <svg class="check-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="8" stroke="#3981F6" stroke-width="1.5"/>
            <path d="M5.5 9L7.5 11L12.5 6.5" stroke="#3981F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <strong>No data is transmitted to external servers.</strong> The only thing sent is the share link you choose to send.
          </div>
        </li>
        <li class="policy-item">
          <svg class="check-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="8" stroke="#3981F6" stroke-width="1.5"/>
            <path d="M5.5 9L7.5 11L12.5 6.5" stroke="#3981F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <strong>Shared links contain only tab URLs and titles.</strong> These are user-selected and encoded directly into the link itself.
          </div>
        </li>
        <li class="policy-item">
          <svg class="check-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="8" stroke="#3981F6" stroke-width="1.5"/>
            <path d="M5.5 9L7.5 11L12.5 6.5" stroke="#3981F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <strong>Links expire automatically.</strong> Shared content cannot be accessed once a link expires. Stash doesn't have servers, databases, or analytics.
          </div>
        </li>
      </ul>

      <!-- Footer note -->
      <div class="page-foot">
        <a href="/" class="back-link">← Back to home</a>
        <span class="updated">Last updated: 2026</span>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  .page-main {
    background-color: var(--background);
    min-height: 100vh;
    padding-top: 5rem; /* navbar offset */
  }

  .page-container {
    max-width: 44rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  /* Header */
  .page-header {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .page-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted-foreground);
    margin-bottom: 1rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--foreground);
    margin: 0 0 0.875rem;
    line-height: 1.1;
  }

  .page-subtitle {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    margin: 0;
    max-width: 36rem;
  }

  /* Policy list */
  .policy-list {
    list-style: none;
    padding: 0;
    margin: 0 0 3rem;
  }

  .policy-item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.125rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9375rem;
    color: var(--foreground);
    line-height: 1.6;
  }

  .policy-item:first-child {
    border-top: none;
  }

  .policy-item:last-child {
    border-bottom: none;
  }

  .check-icon {
    flex-shrink: 0;
    margin-top: 0.1875rem;
  }

  /* Footer row */
  .page-foot {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .back-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--primary);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .back-link:hover {
    opacity: 0.8;
  }

  .back-link:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .updated {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  @media (min-width: 768px) {
    .page-container {
      padding-top: 5rem;
      padding-bottom: 6rem;
    }

    .page-title {
      font-size: 2.5rem;
    }
  }
</style>
