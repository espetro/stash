---
// Features section with outcome-led card grid
// StoryBrand: Lead with outcomes, not functionality
// CRO: Clear value proposition

import FeatureCard from './FeatureCard.astro';

const features = [
  {
    icon: '🔗',
    title: 'Share Your Context',
    description: 'One link captures your entire research session—recipients see exactly what you see',
  },
  {
    icon: '🔒',
    title: 'Private by Design',
    description: 'Everything stays local. No accounts, no cloud, no tracking. Your tabs never leave your machine',
  },
  {
    icon: '⏰',
    title: 'Self-Destructing Links',
    description: 'Set expiration times. Shared sessions automatically expire—perfect for sensitive research',
  },
  {
    icon: '🌙',
    title: 'Works Your Way',
    description: 'Light or dark theme, Chrome or Firefox. Review saved tabs anywhere, anytime',
  },
];
---

<section class="features-section" id="features">
  <div class="features-container">
    <header class="features-header">
      <h2 class="headline">Built for How You Work</h2>
      <p class="subheadline">Features designed around your workflow, not the other way around</p>
    </header>

    <div class="features-grid">
      {features.map((feature) => (
        <FeatureCard
          icon={feature.icon}
          title={feature.title}
          description={feature.description}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background-color: var(--muted);
    padding: 4rem 1.5rem;
  }

  .features-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .headline {
    color: var(--foreground);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem 0;
  }

  .subheadline {
    color: var(--muted-foreground);
    font-size: 1.0625rem;
    line-height: 1.6;
    margin: 0;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  /* Tablet: 2 columns */
  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Desktop: 4 columns */
  @media (min-width: 1024px) {
    .features-section {
      padding: 5rem 2rem;
    }

    .headline {
      font-size: 2.5rem;
    }

    .subheadline {
      font-size: 1.125rem;
    }

    .features-header {
      margin-bottom: 3.5rem;
    }

    .features-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.75rem;
    }
  }

  /* Large desktop */
  @media (min-width: 1280px) {
    .features-section {
      padding: 6rem 2rem;
    }

    .features-grid {
      gap: 2rem;
    }
  }
</style>
