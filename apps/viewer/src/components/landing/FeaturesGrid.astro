---
// Features section — 6 cards, 3-column grid, Lucide icons, scroll-reveal

import { Link, Lock, Cpu, WifiOff, Tag, RotateCcw } from '@lucide/astro';
import FeatureCard from './FeatureCard.astro';

const features = [
  {
    icon: Link,
    label: 'SHARING',
    title: 'One-link context sharing',
    description: 'Share all open tabs as a single URL. Teammates open it, they see your exact session.',
  },
  {
    icon: Lock,
    label: 'PRIVACY',
    title: 'Local-first. Always.',
    description: 'Your data never leaves your machine unless you choose to share. No account. No sync server.',
  },
  {
    icon: Cpu,
    label: 'WORKFLOW',
    title: 'AI-ready context',
    description: 'Export your current session as structured context for any LLM. Paste your tabs directly into your workflow.',
  },
  {
    icon: WifiOff,
    label: 'RELIABILITY',
    title: 'Works offline',
    description: 'Save sessions even without internet. Read them back anytime.',
  },
  {
    icon: Tag,
    label: 'ORGANIZATION',
    title: 'Named sessions',
    description: 'Organize tab groups with names and timestamps. Your context, labeled.',
  },
  {
    icon: RotateCcw,
    label: 'CONTROL',
    title: 'Instant restore',
    description: 'Open an entire saved session in one click. Tabs reopen exactly where you left off.',
  },
];
---

<section class="features-section" id="features">
  <div class="features-container">
    <header class="features-header">
      <h2 class="headline">Everything you need. Nothing you don't.</h2>
    </header>

    <div class="features-grid">
      {features.map((feature) => (
        <FeatureCard
          icon={feature.icon}
          label={feature.label}
          title={feature.title}
          description={feature.description}
        />
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.feature-card').forEach((card, i) => {
    (card as HTMLElement).style.transitionDelay = `${i * 60}ms`;
    observer.observe(card);
  });
</script>

<style>
  .features-section {
    background-color: var(--background);
    padding: 5rem 1.5rem;
    border-top: 1px solid var(--border);
  }

  .features-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .headline {
    color: var(--foreground);
    font-size: 1.875rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-section {
      padding: 7rem 2rem;
    }

    .features-header {
      margin-bottom: 3.5rem;
    }

    .features-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
</style>
