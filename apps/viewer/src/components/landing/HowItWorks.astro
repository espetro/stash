---
// How It Works — 3-step horizontal flow
---

<section class="dark bg-background py-20 px-6 border-t border-border lg:py-28 lg:px-8" id="how-it-works">
  <div class="max-w-7xl mx-auto">
    <header class="mb-12">
      <h2 class="text-3xl font-semibold text-foreground tracking-tight m-0">Three steps.</h2>
    </header>

    <div class="flex flex-col gap-10 lg:flex-row lg:gap-0 lg:items-start">
      <!-- Step 1 -->
      <div class="flex flex-col gap-3 relative lg:flex-1 lg:pr-12">
        <span class="font-mono text-[3rem] font-semibold text-primary leading-none block">01</span>
        <div class="hidden lg:block absolute top-[1.5rem] right-0 w-12 h-px bg-border" aria-hidden="true"></div>
        <h3 class="text-lg font-semibold text-foreground m-0 tracking-tight">Open Stash</h3>
        <p class="text-[0.9375rem] text-muted-foreground leading-relaxed m-0 max-w-[22rem] lg:max-w-none">Click the extension icon while browsing. Your current tabs appear instantly.</p>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col gap-3 relative lg:flex-1 lg:pr-12">
        <span class="font-mono text-[3rem] font-semibold text-primary leading-none block">02</span>
        <div class="hidden lg:block absolute top-[1.5rem] right-0 w-12 h-px bg-border" aria-hidden="true"></div>
        <h3 class="text-lg font-semibold text-foreground m-0 tracking-tight">Save or share</h3>
        <p class="text-[0.9375rem] text-muted-foreground leading-relaxed m-0 max-w-[22rem] lg:max-w-none">Hit "Save session" to store locally, or "Copy link" to share your exact context.</p>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col gap-3 relative lg:flex-1 lg:pr-0">
        <span class="font-mono text-[3rem] font-semibold text-primary leading-none block">03</span>
        <h3 class="text-lg font-semibold text-foreground m-0 tracking-tight">Restore anytime</h3>
        <p class="text-[0.9375rem] text-muted-foreground leading-relaxed m-0 max-w-[22rem] lg:max-w-none">Open any saved session with one click. Tabs reopen exactly as you left them.</p>
      </div>
    </div>
  </div>
</section>
