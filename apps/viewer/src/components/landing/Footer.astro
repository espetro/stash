---
// Footer — minimal single-line bar
---

<footer class="footer">
  <div class="footer-inner">
    <span class="footer-copy">© 2026 Stash — Made with care for power users. <span class="version">v{import.meta.env.APP_VERSION}</span></span>
    <nav class="footer-links" aria-label="Footer links">
      <a href="https://github.com/espetro/stash" class="footer-link" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="/privacy" class="footer-link">Privacy</a>
      <a href="/terms" class="footer-link">Terms</a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
        <span class="theme-icon" id="theme-icon">◐</span>
      </button>
    </nav>
  </div>
</footer>

<script>
  import { getTheme, setTheme } from '@stash/theme';

  const themeToggle = document.getElementById('theme-toggle');
  const themeIcon = document.getElementById('theme-icon');

  if (themeToggle && themeIcon) {
    const updateIcon = (theme: string) => {
      switch (theme) {
        case 'light':
          themeIcon.textContent = '☀️';
          break;
        case 'dark':
          themeIcon.textContent = '☾';
          break;
        default:
          themeIcon.textContent = '◐';
      }
    };

    const cycleTheme = () => {
      const current = getTheme(localStorage);
      let next: string;

      switch (current) {
        case 'light':
          next = 'dark';
          break;
        case 'dark':
          next = 'system';
          break;
        default:
          next = 'light';
      }

      setTheme(next, localStorage);
      updateIcon(next);
      document.documentElement.setAttribute('data-theme', next);
    };

    updateIcon(getTheme(localStorage));
    themeToggle.addEventListener('click', cycleTheme);
  }
</script>

<style>
  .footer {
    background-color: var(--background);
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--foreground);
  }

  .footer-link:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .theme-toggle {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-foreground);
    transition: color 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-toggle:hover {
    color: var(--foreground);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .theme-icon {
    display: inline-block;
    font-size: 1rem;
  }

  .version {
    opacity: 0.6;
    margin-left: 0.25rem;
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
