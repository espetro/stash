---
// Minimal footer for landing page
---

<footer class="footer">
  <div class="footer-container">
    <!-- Text Links -->
    <nav class="footer-links" aria-label="Legal">
      <a href="/privacy" class="footer-link">Privacy Policy</a>
      <a href="/terms" class="footer-link">Terms</a>
      <a href="mailto:habibi.viewpoint219@passinbox.com" class="footer-link">Contact</a>
    </nav>

    <!-- Social Icons -->
    <div class="footer-social">
      <a 
        href="https://github.com/espetro/stash" 
        class="social-link" 
        target="_blank" 
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/>
        </svg>
      </a>
      <a 
        href="https://twitter.com/josocjoq" 
        class="social-link" 
        target="_blank" 
        rel="noopener noreferrer"
        aria-label="Twitter"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    </div>

    <!-- Copyright -->
    <p class="footer-copyright">
      © 2026 Stash. Open source under <a href="https://opensource.org/licenses/MIT" class="license-link" target="_blank" rel="noopener noreferrer">MIT License</a>.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background-color: var(--background);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-link {
    color: var(--muted-foreground);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--foreground);
  }

  .footer-link:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted-foreground);
    transition: color 0.2s ease;
  }

  .social-link:hover {
    color: var(--primary);
  }

  .social-link:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .footer-copyright {
    color: var(--muted-foreground);
    font-size: 0.8125rem;
    margin: 0;
  }

  .license-link {
    color: var(--muted-foreground);
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .license-link:hover {
    color: var(--foreground);
  }

  /* Desktop: horizontal layout */
  @media (min-width: 640px) {
    .footer-container {
      flex-direction: row;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .footer-copyright {
      order: -1;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 639px) {
    .footer-container {
      padding: 1.5rem 1rem;
    }
  }
</style>
