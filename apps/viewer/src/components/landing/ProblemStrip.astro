---
// Social Proof Strip — thin bar with credibility statement
---

<section class="proof-strip bg-background border-t border-b border-border py-5 px-6">
  <div class="proof-container max-w-7xl mx-auto flex items-center justify-center gap-6 flex-wrap">
    <span class="proof-label font-mono text-[0.8125rem] text-muted-foreground">Used by teams at</span>
    <div class="proof-companies flex items-center gap-3 flex-wrap">
      <span class="company font-mono text-sm font-medium text-foreground">YC-backed startups</span>
      <span class="sep text-border text-sm">·</span>
      <span class="company font-mono text-sm font-medium text-foreground">Indie builders</span>
    </div>
  </div>
</section>
