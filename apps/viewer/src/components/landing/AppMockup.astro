---
const DEMO_STASH = [
    "https://github.com/espetro/stash",
    "https://docs.astro.build/",
    "https://calca.illo.fyi",
    "https://ui.land/",
] as const;
---

<div class="flex justify-center items-center">
    <div class="bg-[#11151e] border border-[#1e2438] rounded-[10px] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.4),0_0_0_1px_rgba(0,0,0,0.1)] w-full max-w-[320px] mx-auto">
        <div class="p-3.5 px-4 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <img
                    src="/icon-48.png"
                    width="16"
                    height="16"
                    alt=""
                    aria-hidden="true"
                />
                <span class="font-sans text-[0.875rem] font-semibold text-white">Stash</span>
            </div>
            <span class="text-[#8896ad] text-[1.25rem] leading-[1]" aria-hidden="true">×</span>
        </div>

        <div class="border-b border-[#1e2438]"></div>

        <div class="py-2">
            {
                DEMO_STASH.map((href, index) => (
                    <div id={`${href.slice(8, 20)}-${index}`} class="flex gap-2 p-2 px-4 font-mono text-[0.8125rem] text-[#8896ad] border-b border-[#1e2438] overflow-hidden whitespace-nowrap text-ellipsis last:border-b-0">
                        <a href={href} class="text-[#8896ad]">
                            {href}
                        </a>
                    </div>
                ))
            }
        </div>

        <div class="border-b border-[#1e2438]"></div>

        <div class="p-3.5 px-4 flex flex-col gap-[0.625rem]">
            <button class="bg-[#3981f6] text-white w-full py-2 rounded-md font-sans text-[0.875rem] font-semibold text-center border-none cursor-default">Stash tabs →</button>
            <a href="#" class="text-[#5b9df8] text-[0.8125rem] text-center no-underline font-sans hover:underline">Save session</a>
        </div>
    </div>
</div>
