---
// Reusable feature card component — Lucide icon + label + title + description

interface Props {
  icon: any;
  label: string;
  title: string;
  description: string;
}

const { icon: Icon, label, title, description } = Astro.props;
---

<article
  class="feature-card opacity-0 translate-y-2 transition-all duration-300 bg-card border border-border rounded-xl p-6 flex flex-col gap-2 hover:border-primary/30"
>
  <div class="card-icon mb-2 flex items-center" aria-hidden="true">
    <Icon size={20} class="text-primary" stroke-width={1.5} />
  </div>
  <span
    class="card-label font-mono text-xs uppercase tracking-widest text-muted-foreground leading-none"
    >{label}</span
  >
  <h3
    class="card-title text-[1.0625rem] font-semibold text-foreground m-0 tracking-tight leading-[1.3]"
  >
    {title}
  </h3>
  <p
    class="card-description text-[0.9375rem] leading-[1.6] text-muted-foreground m-0"
  >
    {description}
  </p>
</article>

<style>
  .feature-card.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
