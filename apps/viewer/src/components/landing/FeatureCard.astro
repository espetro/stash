---
// Reusable feature card component — Lucide icon + label + title + description

interface Props {
  icon: any;
  label: string;
  title: string;
  description: string;
}

const { icon: Icon, label, title, description } = Astro.props;
---

<article class="feature-card">
  <div class="card-icon" aria-hidden="true">
    <Icon size={20} color="#3981F6" stroke-width={1.5} />
  </div>
  <span class="card-label">{label}</span>
  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>
</article>

<style>
  .feature-card {
    background-color: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease, border-color 0.15s ease;
  }

  .feature-card.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .feature-card:hover {
    border-color: #BFCFFD;
  }

  .card-icon {
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
  }

  .card-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted-foreground);
    line-height: 1;
  }

  .card-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--foreground);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    margin: 0;
  }
</style>
