---
// Main hero section for landing page
import { FaChrome, FaFirefoxBrowser } from "react-icons/fa6";
import HeroStashPopup from "./HeroStashPopup";
import type { FunctionComponent } from "react";
---

<section class="hero relative overflow-hidden bg-background min-h-[85vh] pt-20 pb-16 flex items-center" id="hero">
  <div class="hero-container relative z-10 max-w-7xl mx-auto px-6 w-full grid grid-cols-1 gap-12">
    <!-- Left Column (60%) -->
    <div class="hero-content flex flex-col gap-6">
      <h1 class="hero-headline font-sans text-[clamp(2.5rem,6vw,4.5rem)] font-bold leading-[1.1] tracking-[-0.03em] m-0">
        <span class="headline-line1 text-foreground">Your tabs are your thinking.</span><br />
        <span class="headline-line2 text-accent">Stop losing them.</span>
      </h1>

      <p class="hero-subheadline font-sans text-lg leading-[1.6] text-muted-foreground m-0 max-w-md">
        Share your entire browser context as one link, or just save it for
        later. Locally. Privately. No account. No cloud. No noise.
      </p>

      <!-- CTA Row -->
      <div class="cta-group flex flex-wrap gap-3 items-center">
        <a
          href="https://github.com/espetro/stash/blob/main/content/docs/getting-started.md"
          class="cta-button cta-primary inline-flex items-center justify-center gap-2 py-2.5 px-5 rounded-md text-[0.9375rem] font-semibold no-underline font-sans transition-colors duration-200 bg-accent text-accent-foreground"
          aria-label="Add Stash to Chrome"
        >
          <FaChrome class="cta-icon w-[1.125rem] h-[1.125rem] flex-shrink-0" aria-hidden="true" />
          Add to Chrome
        </a>

        <a
          href="https://github.com/espetro/stash/blob/main/content/docs/getting-started.md"
          class="cta-button cta-secondary inline-flex items-center justify-center gap-2 py-2.5 px-5 rounded-md text-[0.9375rem] font-semibold no-underline font-sans transition-colors duration-200 bg-card text-foreground border border-border"
          aria-label="Add Stash to Firefox"
        >
          <FaFirefoxBrowser class="cta-icon w-[1.125rem] h-[1.125rem] flex-shrink-0" aria-hidden="true" />
          Add to Firefox
        </a>

        <a href="/s/new" class="cta-button cta-ghost inline-flex items-center justify-center gap-2 py-2.5 px-5 rounded-md text-[0.9375rem] font-semibold no-underline font-sans transition-colors duration-200 text-muted-foreground"> Try in browser → </a>
      </div>

      <p class="cta-tagline font-mono text-xs text-accent m-0 w-full">Free · No account required · Works offline</p>
    </div>

    <!-- Right Column (40%) - HeroStashPopup -->
    <div class="popup-wrapper max-w-[360px] w-full">
      <HeroStashPopup client:only="react" />
    </div>
  </div>
</section>

<style>
  /* Desktop: 60/40 split */
  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 60% 40%;
      align-items: center;
      gap: 4rem;
    }

    .hero-content {
      gap: 1.75rem;
    }
  }

  /* Popup wrapper */
  .popup-wrapper {
    max-width: 360px;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .popup-wrapper {
      max-width: none;
    }
  }

  /* Unavoidable focus-visible and hover states */
  .cta-button:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .cta-primary:hover {
    background-color: var(--accent);
    opacity: 0.9;
  }

  .cta-secondary:hover {
    border-color: var(--border);
  }

  .cta-ghost:hover {
    color: var(--foreground);
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .hero {
      padding-top: 4rem;
      min-height: 90vh;
    }

    .hero-headline {
      font-size: 2rem;
    }

    .hero-subheadline {
      font-size: 1rem;
    }

    .cta-button {
      width: 100%;
      max-width: 200px;
      justify-content: center;
    }

    .popup-wrapper {
      margin-top: 2rem;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
