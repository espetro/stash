---
// Main hero section for landing page
import { FaChrome, FaFirefoxBrowser } from 'react-icons/fa6';
---

<section class="hero" id="hero">
  <div class="hero-container">
    <!-- Left Column (60%) -->
    <div class="hero-content">
      <h1 class="hero-headline">
        <span class="headline-line1">Your tabs are your thinking.</span><br />
        <span class="headline-line2">Stop losing them.</span>
      </h1>
      
      <p class="hero-subheadline">
        Share your entire browser context as one link — or save it for later. Locally. Privately. No account. No cloud. No noise.
      </p>
      
      <!-- CTA Row -->
      <div class="cta-group">
        <a href="#" class="cta-button cta-primary" aria-label="Add Stash to Chrome">
          <FaChrome class="cta-icon" aria-hidden="true" />
          Add to Chrome
        </a>
        
        <a href="#" class="cta-button cta-secondary" aria-label="Add Stash to Firefox">
          <FaFirefoxBrowser class="cta-icon" aria-hidden="true" />
          Add to Firefox
        </a>
      </div>
      
      <p class="cta-tagline">
        Free · No account required · Works offline
      </p>
    </div>
    
    <!-- Right Column (40%) - Popup Mockup -->
    <div class="popup-wrapper">
      <div class="popup-card">
        <div class="popup-header">
          <div class="popup-brand">
            <img src="/icon-48.png" width="16" height="16" alt="" aria-hidden="true" />
            <span class="popup-title">Stash</span>
          </div>
          <span class="popup-close" aria-hidden="true">×</span>
        </div>
        
        <div class="popup-divider"></div>
        
        <div class="popup-tabs">
          <div class="popup-tab">github.com/espetro/st..</div>
          <div class="popup-tab">docs.astro.build</div>
          <div class="popup-tab">tailwindcss.com/docs</div>
          <div class="popup-tab">mdn.mozilla.org/en-US</div>
        </div>
        
        <div class="popup-divider"></div>
        
        <div class="popup-actions">
          <button class="popup-button">Stash tabs →</button>
          <a href="#" class="popup-secondary-link">Save session</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 85vh;
    padding-top: 5rem;
    padding-bottom: 4rem;
    display: flex;
    align-items: center;
    background-color: var(--background);
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    position: relative;
    z-index: 1;
  }

  /* Left Column */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-headline {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .headline-line1 {
    color: var(--foreground);
  }

  .headline-line2 {
    color: #3981F6;
  }

  .hero-subheadline {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    margin: 0;
    max-width: 28rem;
  }

  /* CTA Row */
  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    font-family: var(--font-sans);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .cta-primary {
    background-color: #3981F6;
    color: #ffffff;
  }

  .cta-primary:hover {
    background-color: #2563EB;
  }

  .cta-secondary {
    background-color: #ffffff;
    color: var(--foreground);
    border: 1px solid var(--border);
  }

  .cta-secondary:hover {
    border-color: #C0C8D8;
  }

  .cta-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
  }

  .cta-tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-foreground);
    margin: 0;
    width: 100%;
  }

  /* Right Column - Popup */
  .popup-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .popup-card {
    background-color: #11151E;
    border: 1px solid #1E2438;
    border-radius: 10px;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.4), 0 0 0 1px rgba(0,0,0,0.1);
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
  }

  .popup-header {
    padding: 0.875rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .popup-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .popup-title {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
  }

  .popup-close {
    color: #8896AD;
    font-size: 1.25rem;
    line-height: 1;
  }

  .popup-divider {
    border-bottom: 1px solid #1E2438;
  }

  .popup-tabs {
    padding: 0.5rem 0;
  }

  .popup-tab {
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: #8896AD;
    border-bottom: 1px solid #1E2438;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .popup-tab:last-child {
    border-bottom: none;
  }

  .popup-actions {
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .popup-button {
    background-color: #3981F6;
    color: #ffffff;
    width: 100%;
    padding: 0.5rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
    font-family: var(--font-sans);
    border: none;
    cursor: default;
  }

  .popup-secondary-link {
    color: #5B9DF8;
    font-size: 0.8125rem;
    text-align: center;
    text-decoration: none;
    font-family: var(--font-sans);
  }

  .popup-secondary-link:hover {
    text-decoration: underline;
  }

  /* Desktop: 60/40 split */
  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 60% 40%;
      align-items: center;
      gap: 4rem;
    }

    .hero-content {
      gap: 1.75rem;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .hero {
      padding-top: 4rem;
      min-height: 90vh;
    }

    .hero-headline {
      font-size: 2rem;
    }

    .hero-subheadline {
      font-size: 1rem;
    }

    .cta-button {
      width: 100%;
      max-width: 200px;
      justify-content: center;
    }

    .popup-wrapper {
      margin-top: 2rem;
    }
  }
</style>
