---
// Main hero section for landing page
import { FaChrome, FaFirefoxBrowser } from "react-icons/fa6";
import HeroStashPopup from "./HeroStashPopup";
import type { FunctionComponent } from "react";
---

<section class="hero" id="hero">
  <div class="hero-container">
    <!-- Left Column (60%) -->
    <div class="hero-content">
      <h1 class="hero-headline">
        <span class="headline-line1">Your tabs are your thinking.</span><br />
        <span class="headline-line2">Stop losing them.</span>
      </h1>

      <p class="hero-subheadline">
        Share your entire browser context as one link, or just save it for
        later. Locally. Privately. No account. No cloud. No noise.
      </p>

      <!-- CTA Row -->
      <div class="cta-group">
        <a
          href="https://github.com/espetro/stash/blob/main/content/docs/getting-started.md"
          class="cta-button cta-primary"
          aria-label="Add Stash to Chrome"
        >
          <FaChrome class="cta-icon" aria-hidden="true" />
          Add to Chrome
        </a>

        <a
          href="https://github.com/espetro/stash/blob/main/content/docs/getting-started.md"
          class="cta-button cta-secondary"
          aria-label="Add Stash to Firefox"
        >
          <FaFirefoxBrowser class="cta-icon" aria-hidden="true" />
          Add to Firefox
        </a>

        <a href="/s/new" class="cta-button cta-ghost"> Try in browser → </a>
      </div>

      <p class="cta-tagline">Free · No account required · Works offline</p>
    </div>

    <!-- Right Column (40%) - HeroStashPopup -->
    <div class="popup-wrapper">
      <HeroStashPopup client:only="react" />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 85vh;
    padding-top: 5rem;
    padding-bottom: 4rem;
    display: flex;
    align-items: center;
    background-color: var(--background);
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    position: relative;
    z-index: 1;
  }

  /* Left Column */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-headline {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .headline-line1 {
    color: var(--foreground);
  }

  .headline-line2 {
    color: #3981f6;
  }

  .hero-subheadline {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    margin: 0;
    max-width: 28rem;
  }

  /* CTA Row */
  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    font-family: var(--font-sans);
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .cta-primary {
    background-color: #3981f6;
    color: #ffffff;
  }

  .cta-primary:hover {
    background-color: #2563eb;
  }

  .cta-secondary {
    background-color: #ffffff;
    color: var(--foreground);
    border: 1px solid var(--border);
  }

  .cta-secondary:hover {
    border-color: #c0c8d8;
  }

  .cta-ghost {
    background-color: transparent;
    color: var(--muted-foreground);
    border: none;
  }

  .cta-ghost:hover {
    color: var(--foreground);
  }

  .cta-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
  }

  .cta-tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-foreground);
    margin: 0;
    width: 100%;
  }

  /* Desktop: 60/40 split */
  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 60% 40%;
      align-items: center;
      gap: 4rem;
    }

    .hero-content {
      gap: 1.75rem;
    }
  }

  /* Popup wrapper */
  .popup-wrapper {
    max-width: 360px;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .popup-wrapper {
      max-width: none;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .hero {
      padding-top: 4rem;
      min-height: 90vh;
    }

    .hero-headline {
      font-size: 2rem;
    }

    .hero-subheadline {
      font-size: 1rem;
    }

    .cta-button {
      width: 100%;
      max-width: 200px;
      justify-content: center;
    }

    .popup-wrapper {
      margin-top: 2rem;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
