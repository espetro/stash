---
// Final CTA — dark #0B0E15 background, centered, generous padding
import { FaChrome, FaFirefoxBrowser } from 'react-icons/fa6';
---

<section class="final-cta">
  <div class="cta-container">
    <span class="cta-label">FREE BROWSER EXTENSION</span>

    <h2 class="cta-headline">Stop losing your context.</h2>

    <p class="cta-subheadline">
      Add Stash to your browser in 30 seconds.
    </p>

    <div class="cta-group">
      <a href="#" class="cta-button cta-primary" aria-label="Add Stash to Chrome">
        <FaChrome class="cta-icon" aria-hidden="true" />
        Add to Chrome
      </a>

      <a href="#" class="cta-button cta-secondary" aria-label="Add Stash to Firefox">
        <FaFirefoxBrowser class="cta-icon" aria-hidden="true" />
        Add to Firefox
      </a>
    </div>

    <p class="cta-footnote">No account · No cloud · Works offline</p>
  </div>
</section>

<style>
  .final-cta {
    background-color: #0B0E15;
    padding: 8rem 1.5rem;
    text-align: center;
  }

  .cta-container {
    max-width: 44rem;
    margin: 0 auto;
  }

  .cta-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #8896AD;
    margin-bottom: 1.25rem;
  }

  .cta-headline {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #EBEEF6;
    margin: 0 0 1rem;
  }

  .cta-subheadline {
    font-size: 1.125rem;
    line-height: 1.6;
    color: #8896AD;
    margin: 0 0 2.5rem;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .cta-button:focus-visible {
    outline: 2px solid #5B9DF8;
    outline-offset: 2px;
  }

  .cta-primary {
    background-color: #3981F6;
    color: #ffffff;
  }

  .cta-primary:hover {
    background-color: #2563EB;
  }

  .cta-secondary {
    background-color: transparent;
    color: #EBEEF6;
    border: 1px solid #EBEEF6;
  }

  .cta-secondary:hover {
    border-color: #ffffff;
    background-color: rgba(255, 255, 255, 0.05);
  }

  .cta-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
  }

  .cta-footnote {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #8896AD;
    margin: 1.25rem 0 0;
  }

  @media (max-width: 639px) {
    .cta-button {
      width: 100%;
      max-width: 260px;
    }
  }

  @media (min-width: 1024px) {
    .final-cta {
      padding: 10rem 2rem;
    }
  }
</style>
