<style>
  .final-cta {
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .cta-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-headline {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 1rem 0;
  }

  .cta-subheadline {
    font-size: 1.125rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 2.5rem 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  /* CTA Buttons - Inverted style from hero */
  .cta-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    min-width: 200px;
  }

  .cta-button:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }

  /* Chrome: White bg, primary text */
  .cta-chrome {
    background-color: #ffffff;
    color: #3981f6;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15);
  }

  .cta-chrome:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
    filter: brightness(0.97);
  }

  /* Firefox: Transparent bg, white border */
  .cta-firefox {
    background-color: transparent;
    color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.8);
  }

  .cta-firefox:hover {
    transform: translateY(-2px);
    background-color: rgba(255, 255, 255, 0.1);
    border-color: #ffffff;
  }

  .cta-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  /* Desktop: buttons side by side */
  @media (min-width: 640px) {
    .cta-group {
      flex-direction: row;
    }

    .cta-headline {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 768px) {
    .final-cta {
      padding: 6rem 1.5rem;
    }

    .cta-headline {
      font-size: 2.75rem;
    }

    .cta-subheadline {
      font-size: 1.25rem;
    }

    .cta-button {
      padding: 1rem 2rem;
      font-size: 1.0625rem;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 639px) {
    .cta-button {
      width: 100%;
      max-width: 280px;
    }
  }
</style>
