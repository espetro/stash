---
// Status-aware roadmap cell component
// Variants: done (green checkmark), upcoming (clock), suggest (dashed + icon)

interface Props {
  status: 'done' | 'upcoming' | 'suggest';
  label: string;
  href?: string;
}

const { status, label, href } = Astro.props;

const isSuggest = status === 'suggest';
const Element = isSuggest ? 'a' : 'div';
const linkProps = isSuggest && href ? { href, target: '_blank', rel: 'noopener noreferrer' } : {};
---

<Element class:list={['roadmap-cell relative flex items-center justify-center min-h-14 py-3 px-4 bg-card border border-border rounded-lg transition-all duration-200', `status-${status}`]} {...linkProps}>
  {status === 'done' && (
    <span class="badge absolute top-[0.375rem] right-2 text-xs font-bold leading-none text-[#22c55e]" aria-label="Shipped">✓</span>
  )}
  {status === 'upcoming' && (
    <span class="badge absolute top-[0.375rem] right-2 text-[0.625rem] font-bold leading-none" aria-label="Coming soon">🕐</span>
  )}
  {status === 'suggest' && (
    <span class="plus-icon text-xl font-light text-muted-foreground mr-[0.375rem]" aria-hidden="true">+</span>
  )}
  <span class="cell-label text-sm font-medium text-foreground text-center leading-[1.3]">{label}</span>
</Element>

<style>
  .roadmap-cell:hover {
    box-shadow: var(--shadow-md);
  }

  .status-suggest {
    text-decoration: none;
    cursor: pointer;
  }

  .status-suggest:hover {
    border-color: var(--primary);
    background-color: var(--muted);
  }

  .status-suggest:hover .plus-icon {
    color: var(--primary);
  }

  .status-suggest .cell-label {
    color: var(--muted-foreground);
  }

  .status-suggest:hover .cell-label {
    color: var(--foreground);
  }

  .status-suggest:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }
</style>
