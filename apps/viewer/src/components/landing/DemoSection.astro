---
// Demo section — dark background with browser session mockup

const DEMO_STASH = [
  "https://github.com/withastro/astro/releases/tag/astro%405.0.0",
  "https://docs.astro.build/en/guides/upgrade-to/v5/",
  "https://tailwindcss.com/docs/v4-beta",
  "https://stackoverflow.com/questions/79124/astro-content-collections-migration",
  "https://mdn.mozilla.org/en-US/docs/Web/CSS/animation-timeline",
] as const;

const DEMO_LINK =
  "https://stash.illo.fyi/s/#p=CG6gBAIzEOCbyIriidu9-w1LA2-0wDZGk-avfX0iEtNBWwTOPkkhrhqDKZ39_E-wD8mxsHHNx2D2kLrd0c9FQRIfOxcPF60XyhrTeBPZHn99fegm13ct043jklvrBgQ5aQXmCJs62QNIc91tvMpiyARtcMyOhhnC9mRgFi9VY6wVaMUrbxzIdwkegBPkU3xYJ1QXKSPNCjfpGURRGwzPkExA09ArAqWg3FaQZgfqkuwcdcL4cjiZNGMDKEwi0gGz4g3Qnq4zMmMmeyXKwYjjuS_TPlr6Nc67FXgTWAXmRNRTolRlJ-j7P8lZNq7Kb07-eAQ";
---

<section class="bg-[#0b0e15] py-20 px-6 lg:py-28 lg:px-8" id="demo">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-semibold text-[#ebeef6] tracking-[-0.02em] mb-10 text-center lg:text-2xl lg:mb-12">See it in action</h2>

    <!-- Browser session mockup -->
    <div class="bg-[#11151e] border border-[#1e2438] rounded-[10px] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.5)] overflow-hidden text-left">
      <!-- Chrome bar -->
      <div class="bg-[#161b28] py-3 px-4 border-b border-[#1e2438] flex items-center gap-3">
        <div class="flex gap-1.5 flex-shrink-0" aria-hidden="true">
          <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
        </div>
        <div class="flex-1 bg-[#0b0e15] border border-[#1e2438] rounded-md py-1 px-3 font-mono text-[0.75rem] text-[#5b9df8] overflow-hidden whitespace-nowrap text-ellipsis" aria-label="URL bar">
          {DEMO_LINK.slice(0, 60)}...
        </div>
      </div>

      <!-- Session content -->
      <div class="p-5 px-6">
        <span class="font-mono text-[0.6875rem] uppercase tracking-[0.1em] text-[#5b9df8] block mb-2">SAVED SESSION</span>
        <p class="text-base font-semibold text-[#ebeef6] m-0 mb-5">Research: Astro 5 Migration</p>

        <div class="flex flex-col" role="list">
          {
            DEMO_STASH.map((href, index) => (
              <div class="flex items-center gap-3 py-2 border-b border-[#1e2438] last:border-b-0" role="listitem">
                <span class="font-mono text-[0.75rem] text-[#8896ad] min-w-[1rem] flex-shrink-0">{index}</span>
                <span class="font-mono text-[0.8125rem] text-[#8896ad] overflow-hidden whitespace-nowrap text-ellipsis">{href}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <a
      href={DEMO_LINK}
      class="block mt-6 text-[#5b9df8] text-[0.9375rem] no-underline hover:underline focus:outline-2 focus:outline-[#5b9df8] focus:outline-offset-2 focus:rounded-sm text-center"
      target="_blank"
      rel="noopener noreferrer">View a live example →</a
    >
  </div>
</section>
