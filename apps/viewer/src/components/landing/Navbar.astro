---
// Sticky navigation bar for landing page

interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;

import { INSTALL_CHROME_URL, INSTALL_FIREFOX_URL } from "@/lib/constants";
---

<nav
  class="navbar fixed top-0 left-0 right-0 z-100 bg-card transition-all duration-300 border-b border-transparent"
  id="navbar"
>
  <!-- Sentinel for scroll detection -->
  <div id="nav-sentinel" class="sentinel"></div>

  <div
    class="navbar-container max-w-7xl mx-auto px-6 py-3.5 grid grid-cols-[auto_1fr_auto] items-center gap-6"
  >
    <!-- Logo -->
    <a
      href="/"
      class="logo flex items-center gap-2 no-underline transition-opacity duration-200 justify-self-start"
    >
      <img
        src="/icon-128.png"
        width="40"
        height="40"
        alt=""
        aria-hidden="true"
        class="logo-icon block flex-shrink-0"
      />
      <span
        class="logo-text text-lg font-semibold text-foreground tracking-tight"
        >Stash</span
      >
    </a>

    <!-- Nav Links -->
    <div class="nav-links flex items-center gap-8 justify-self-center">
      {
        minimal ? (
          <a
            href="/"
            class="nav-link text-foreground no-underline text-[0.9375rem] font-medium font-sans relative pb-0.5"
          >
            Home
          </a>
        ) : (
          <>
            <a
              href="#features"
              class="nav-link text-foreground no-underline text-[0.9375rem] font-medium font-sans relative pb-0.5"
            >
              Features
            </a>
            <a
              href="#how-it-works"
              class="nav-link text-foreground no-underline text-[0.9375rem] font-medium font-sans relative pb-0.5"
            >
              How it works
            </a>
            <a
              href="#demo"
              class="nav-link text-foreground no-underline text-[0.9375rem] font-medium font-sans relative pb-0.5"
            >
              Demo
            </a>
          </>
        )
      }
    </div>

    <!-- Install Dropdown -->
    <div
      class="install-dropdown justify-self-end relative"
      id="install-dropdown"
    >
      <button
        class="cta-button bg-accent text-accent-foreground py-2 px-4 rounded-md text-[0.875rem] font-semibold no-underline transition-colors duration-200 font-sans dropdown-trigger flex items-center cursor-pointer"
        id="install-trigger"
        aria-expanded="false"
        aria-haspopup="true"
      >
        Install ▾
      </button>
      <div
        class="dropdown-menu absolute top-full right-0 bg-card border border-border rounded-md min-w-48 py-2 mt-2 shadow-md opacity-0 invisible -translate-y-2 transition-all duration-200 z-10"
        id="install-menu"
        role="menu"
      >
        <a
          href={INSTALL_CHROME_URL}
          class="dropdown-item block py-2.5 px-4 text-foreground no-underline text-[0.875rem] font-medium font-sans transition-colors duration-150"
          role="menuitem"
        >
          Add to Chrome
        </a>
        <a
          href={INSTALL_FIREFOX_URL}
          class="dropdown-item block py-2.5 px-4 text-foreground no-underline text-[0.875rem] font-medium font-sans transition-colors duration-150"
          role="menuitem"
        >
          Add to Firefox
        </a>
        <div class="dropdown-divider h-px bg-border my-2"></div>
        <a
          href="/s/new"
          class="dropdown-item block py-2.5 px-4 text-foreground no-underline text-[0.875rem] font-medium font-sans transition-colors duration-150"
          role="menuitem"
        >
          Try in browser →
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Scroll detection
  const sentinel = document.getElementById("nav-sentinel");
  const navbar = document.getElementById("navbar");

  if (sentinel && navbar) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            navbar.classList.add("scrolled");
          } else {
            navbar.classList.remove("scrolled");
          }
        });
      },
      {
        threshold: 0,
        rootMargin: "0px 0px 0px 0px",
      },
    );

    observer.observe(sentinel);
  }

  // Dropdown menu behavior
  const dropdown = document.getElementById("install-dropdown");
  const trigger = document.getElementById("install-trigger");
  const menu = document.getElementById("install-menu");

  if (dropdown && trigger && menu) {
    // Toggle dropdown on click for mobile
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.toggle("open");
      trigger.setAttribute("aria-expanded", String(isOpen));
    });

    // Close dropdown on outside click
    document.addEventListener("click", (e) => {
      if (!dropdown.contains(e.target as Node)) {
        dropdown.classList.remove("open");
        trigger.setAttribute("aria-expanded", "false");
      }
    });

    // Close dropdown on menu item click
    menu.querySelectorAll(".dropdown-item").forEach((item) => {
      item.addEventListener("click", () => {
        dropdown.classList.remove("open");
        trigger.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>

<style>
  .sentinel {
    position: absolute;
    top: 50px;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .navbar.scrolled {
    background-color: var(--card);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }

  .logo:hover {
    opacity: 0.85;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--primary);
    transition: width 0.2s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .cta-button:hover {
    background-color: color-mix(in srgb, var(--accent) 85%, transparent);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .install-dropdown:hover .dropdown-menu,
  .install-dropdown.open .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item:hover {
    background-color: var(--muted);
  }

  .dropdown-item:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: -2px;
  }

  /* Mobile responsive */
  @media (max-width: 767px) {
    .navbar-container {
      padding: 0.75rem 1rem;
      grid-template-columns: auto 1fr;
    }

    .nav-links {
      display: none;
    }

    .logo-text {
      font-size: 1rem;
    }

    .cta-button {
      font-size: 0.8125rem;
      padding: 0.5rem 0.875rem;
    }

    .dropdown-menu {
      right: -0.5rem;
    }
  }

  @media (max-width: 767px) and (hover: none) {
    .dropdown-menu {
      display: none;
    }

    .install-dropdown.open .dropdown-menu {
      display: block;
    }
  }
</style>
