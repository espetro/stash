---
// Sticky navigation bar for landing page
---

<nav class="navbar" id="navbar">
  <!-- Sentinel for scroll detection -->
  <div id="nav-sentinel" class="sentinel"></div>
  
  <div class="navbar-container">
    <!-- Logo -->
    <a href="/" class="logo">
      <img src="/icon-48.png" width="32" height="32" alt="" aria-hidden="true" class="logo-icon" />
      <span class="logo-text">Stash</span>
    </a>

    <!-- Nav Links -->
    <div class="nav-links">
      <a href="#features" class="nav-link">Features</a>
      <a href="#how-it-works" class="nav-link">How it works</a>
      <a href="#demo" class="nav-link">Demo</a>
    </div>

    <!-- Install Dropdown -->
    <div class="install-dropdown" id="install-dropdown">
      <button class="cta-button dropdown-trigger" id="install-trigger" aria-expanded="false" aria-haspopup="true">
        Install ▾
      </button>
      <div class="dropdown-menu" id="install-menu" role="menu">
        <a href="https://chrome.google.com/webstore/detail/stash" class="dropdown-item" role="menuitem">
          Add to Chrome
        </a>
        <a href="https://addons.mozilla.org/firefox/addon/stash" class="dropdown-item" role="menuitem">
          Add to Firefox
        </a>
        <div class="dropdown-divider"></div>
        <a href="/s/new" class="dropdown-item" role="menuitem">
          Try in browser →
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Scroll detection
  const sentinel = document.getElementById('nav-sentinel');
  const navbar = document.getElementById('navbar');

  if (sentinel && navbar) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            navbar.classList.add('scrolled');
          } else {
            navbar.classList.remove('scrolled');
          }
        });
      },
      {
        threshold: 0,
        rootMargin: '0px 0px 0px 0px',
      }
    );

    observer.observe(sentinel);
  }

  // Dropdown menu behavior
  const dropdown = document.getElementById('install-dropdown');
  const trigger = document.getElementById('install-trigger');
  const menu = document.getElementById('install-menu');

  if (dropdown && trigger && menu) {
    // Toggle dropdown on click for mobile
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.toggle('open');
      trigger.setAttribute('aria-expanded', String(isOpen));
    });

    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) {
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    // Close dropdown on menu item click
    menu.querySelectorAll('.dropdown-item').forEach((item) => {
      item.addEventListener('click', () => {
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>

<style>
  .sentinel {
    position: absolute;
    top: 50px;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--card);
    transition: background-color 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    border-bottom: 1px solid transparent;
  }

  .navbar.scrolled {
    background-color: var(--card);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }

  .navbar-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.875rem 1.5rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links {
    justify-self: center;
  }

  .install-dropdown {
    justify-self: end;
    position: relative;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease;
    justify-self: start;
  }

  .logo:hover {
    opacity: 0.85;
  }

  .logo-icon {
    display: block;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--foreground);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    color: var(--foreground);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-sans);
    position: relative;
    padding-bottom: 2px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--primary);
    transition: width 0.2s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .cta-button {
    background-color: var(--primary);
    color: var(--primary-foreground);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s ease;
    font-family: var(--font-sans);
  }

  .cta-button:hover {
    background-color: color-mix(in srgb, var(--primary) 85%, transparent);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .dropdown-trigger {
    display: flex;
    align-items: center;
    cursor: pointer;
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    right: 0;
    background-color: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    min-width: 180px;
    padding: 0.5rem 0;
    margin-top: 0.5rem;
    box-shadow: var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    z-index: 10;
  }

  .install-dropdown:hover .dropdown-menu,
  .install-dropdown.open .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    display: block;
    padding: 0.625rem 1rem;
    color: var(--foreground);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-sans);
    transition: background-color 0.15s ease;
  }

  .dropdown-item:hover {
    background-color: var(--muted);
  }

  .dropdown-item:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: -2px;
  }

  .dropdown-divider {
    height: 1px;
    background-color: var(--border);
    margin: 0.5rem 0;
  }

  /* Mobile responsive */
  @media (max-width: 767px) {
    .navbar-container {
      padding: 0.75rem 1rem;
      grid-template-columns: auto 1fr;
    }

    .nav-links {
      display: none;
    }

    .logo-text {
      font-size: 1rem;
    }

    .cta-button {
      font-size: 0.8125rem;
      padding: 0.5rem 0.875rem;
    }

    .dropdown-menu {
      right: -0.5rem;
    }
  }

  @media (max-width: 767px) and (hover: none) {
    .dropdown-menu {
      display: none;
    }

    .install-dropdown.open .dropdown-menu {
      display: block;
    }
  }
</style>
