---
// Privacy Statement — two-column trust section
---

<section
  class="dark bg-background py-20 px-6 border-t border-border lg:py-28 lg:px-8"
>
  <div
    class="max-w-7xl mx-auto flex flex-col gap-10 md:flex-row md:items-start md:gap-16"
  >
    <!-- Left column -->
    <div class="flex flex-col gap-3 md:flex-[0_0_38%]">
      <h2 class="text-3xl font-semibold text-foreground tracking-tight m-0">
        Built for trust.
      </h2>
      <p class="text-base text-muted-foreground m-0 leading-relaxed">
        Zero telemetry, zero cloud, zero compromise.
      </p>
    </div>

    <!-- Right column -->
    <div class="flex-1">
      <ul class="list-none p-0 m-0 flex flex-col gap-4" role="list">
        <li
          class="flex items-start gap-3 text-[0.9375rem] text-foreground leading-relaxed"
        >
          <svg
            class="shrink-0 mt-0.5"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            aria-hidden="true"
          >
            <circle
              cx="9"
              cy="9"
              r="8"
              stroke="var(--primary)"
              stroke-width="1.5"></circle>
            <path
              d="M5.5 9L7.5 11L12.5 6.5"
              stroke="var(--primary)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span>No account required. Never.</span>
        </li>
        <li
          class="flex items-start gap-3 text-[0.9375rem] text-foreground leading-relaxed"
        >
          <svg
            class="shrink-0 mt-0.5"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            aria-hidden="true"
          >
            <circle
              cx="9"
              cy="9"
              r="8"
              stroke="var(--primary)"
              stroke-width="1.5"></circle>
            <path
              d="M5.5 9L7.5 11L12.5 6.5"
              stroke="var(--primary)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span>All sessions stored in your browser's local storage.</span>
        </li>
        <li
          class="flex items-start gap-3 text-[0.9375rem] text-foreground leading-relaxed"
        >
          <svg
            class="shrink-0 mt-0.5"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            aria-hidden="true"
          >
            <circle
              cx="9"
              cy="9"
              r="8"
              stroke="var(--primary)"
              stroke-width="1.5"></circle>
            <path
              d="M5.5 9L7.5 11L12.5 6.5"
              stroke="var(--primary)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span>Sharing is opt-in. Nothing leaves without your action.</span>
        </li>
        <li
          class="flex items-start gap-3 text-[0.9375rem] text-foreground leading-relaxed"
        >
          <svg
            class="shrink-0 mt-0.5"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            aria-hidden="true"
          >
            <circle
              cx="9"
              cy="9"
              r="8"
              stroke="var(--primary)"
              stroke-width="1.5"></circle>
            <path
              d="M5.5 9L7.5 11L12.5 6.5"
              stroke="var(--primary)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span>Open source. Audit it yourself.</span>
        </li>
      </ul>

      <a
        href="https://github.com/espetro/stash"
        class="inline-block mt-6 font-mono text-sm text-primary no-underline hover:underline focus-visible:outline-2 focus-visible:outline-ring focus-visible:outline-offset-2 focus-visible:rounded-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        github.com/espetro/stash →
      </a>
    </div>
  </div>
</section>
