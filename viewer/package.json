{
  "name": "tab-mail-viewer",
  "version": "0.1.0",
  "description": "TabShare viewer site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
