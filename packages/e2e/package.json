{
  "name": "@stash/e2e",
  "version": "0.6.1",
  "description": "E2E tests for Stash browser extension and viewer using Gauge and Playwright",
  "scripts": {
    "test": "gauge run",
    "test:spec": "gauge run specs/",
    "test:parallel": "gauge run --parallel -n 2",
    "test:context-menu": "gauge run specs/extension-context-menu.md",
    "test:link-generation": "gauge run specs/extension-link-generation.md",
    "test:popup": "gauge run specs/extension-popup.md",
    "test:viewer": "gauge run specs/extension-rendering.md",
    "test:e2e": "gauge run specs/end-to-end-integration.md",
    "test:coverage": "gauge run --tags 'coverage'",
    "test:smoke": "gauge run --tags 'smoke'",
    "docs": "gauge docs specs/",
    "tscheck": "tsc --noEmit",
    "lint": "oxlint --fix step_implementations tests helpers && gauge validate specs/",
    "format": "oxfmt --write 'step_implementations/**/*.ts' 'tests/**/*.ts' 'helpers/**/*.ts'",
    "validate": "tsx ../../scripts/validate.ts --cwd packages/e2e"
  }
}
