{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "clean": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "clean"],
      "outputs": [".output/**", "dist/**"],
      "env": ["VITE_VIEWER_ORIGIN"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "zip": {
      "dependsOn": ["build"],
      "outputs": [".output/**"]
    },
    "format": {
      "dependsOn": []
    },
    "lint": {
      "dependsOn": []
    },
    "tscheck": {
      "dependsOn": ["^tscheck"]
    },
    "test": {
      "cache": false
    }
  }
}
