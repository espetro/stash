{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**", "dist/**"],
      "env": ["VITE_VIEWER_ORIGIN"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "zip": {
      "dependsOn": ["build"],
      "outputs": [".output/**"]
    },
    "format": {
      "dependsOn": []
    },
    "lint": {
      "dependsOn": []
    },
    "tscheck": {
      "dependsOn": []
    }
  }
}
